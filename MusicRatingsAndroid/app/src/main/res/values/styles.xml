<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.MusicRatings" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#003686</item>
        <item name="colorPrimaryVariant">#001a33</item>
        <item name="colorOnPrimary">@android:color/white</item>
        
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#1DB954</item>
        <item name="colorSecondaryVariant">#1aa34a</item>
        <item name="colorOnSecondary">@android:color/black</item>
        
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">?attr/colorPrimaryVariant</item>
        
        <!-- Customize your theme here. -->
        <item name="android:colorBackground">#001a33</item>
        <item name="colorOnBackground">@android:color/white</item>
        <item name="colorSurface">#003686</item>
        <item name="colorOnSurface">@android:color/white</item>
    </style>
</resources>
